generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  personId         String?
  eventId          String?
  name             String
  teamId           String?
  profile_image_url String?
  createdAt        DateTime @default(now())

  person           Person?           @relation(fields: [personId], references: [id], onDelete: SetNull)
  event            Event?            @relation(fields: [eventId], references: [id], onDelete: SetNull)
  team             Team?             @relation(fields: [teamId], references: [id])
  drinkLogs        DrinkLog[]
  posts            Post[]
  approvedSightings PublicSighting[]

  @@index([eventId])
  @@index([personId])
  @@unique([eventId, personId])

  @@map("users")
}

model Team {
  id             String   @id @default(cuid())
  eventId        String?
  name           String
  color          String
  seedTag        String?
  logo_image_url String?
  createdAt      DateTime @default(now())

  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  users User[]

  @@index([eventId])
  @@unique([eventId, name])

  @@map("teams")
}

model DrinkLog {
  id        String   @id @default(cuid())
  eventId   String?
  userId    String
  drinkType String
  points    Int
  createdAt DateTime @default(now())

  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId])

  @@map("drink_logs")
}

model Post {
  id        String   @id @default(cuid())
  eventId   String?
  userId    String
  message   String
  image_url String?
  isPrivate Boolean  @default(true)
  createdAt DateTime @default(now())

  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId])

  @@map("posts")
}

model Commentary {
  id           String    @id @default(cuid())
  eventId      String?
  type         String    // 'milestone', 'streak', 'achievement', 'hype', 'team_event'
  message      String    // Generated message text
  priority     Int       @default(1) // 1-5 (5 = highest priority)
  metadata     Json?     // Additional data (userId, teamId, stats, context)
  isDisplayed  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  displayedAt  DateTime?

  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([eventId])

  @@map("commentaries")
}

model Event {
  id              String               @id @default(cuid())
  slug            String               @unique
  name            String
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  users           User[]
  teams           Team[]
  drinkLogs       DrinkLog[]
  posts           Post[]
  commentary       Commentary[]
  triviaCategories TriviaCategory[]
  triviaPowerUsage TriviaPowerUsage[]
  publicSightings  PublicSighting[]
  hypeVotes        HypeVote[]
  hypeEvents       HypeEvent[]
  landingPage      EventLandingPage?

  @@map("events")
}

model EventLandingPage {
  id            String   @id @default(cuid())
  eventId       String   @unique
  event         Event    @relation(fields: [eventId], references: [id])
  title         String
  description   String   @default("")
  galleryImages Json     @default("[]")
  ctaText       String   @default("Enter")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("event_landing_pages")
}

model TriviaCategory {
  id          String   @id @default(cuid())
  eventId     String?
  seedTag     String?
  title       String
  description String?
  status      String   @default("draft") // draft, active, completed
  createdBy   String?
  createdAt   DateTime @default(now())

  event     Event?                 @relation(fields: [eventId], references: [id], onDelete: SetNull)
  questions TriviaQuestion[]
  results   TriviaCategoryResult[]

  @@index([eventId])
  @@map("trivia_categories")
}

model TriviaQuestion {
  id             String   @id @default(cuid())
  categoryId     String
  questionNumber Int      // 1, 2, or 3
  questionText   String
  questionType   String   @default("text") // text, numeric
  correctAnswer  String?
  numericAnswer  Float?
  allowClosest   Boolean  @default(false)
  media          String?
  notes          String?
  createdAt      DateTime @default(now())

  category TriviaCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@map("trivia_questions")
}

model TriviaCategoryResult {
  id                    String   @id @default(cuid())
  categoryId            String
  question1Winner       String?  // userId or null
  question2Winner       String?  // userId or null
  question3Winner       String?  // userId or null
  scenario              String   // Godlike, Two Wins, Steal Yo GF, Single Win, No Score
  categoryWinner        String?  // userId or null
  basePoints            Int      @default(0)
  numericBonus          Int      @default(0)
  finalPoints           Int      @default(0)
  manualOverride        Boolean  @default(false)
  overrideReason        String?
  publishedToScoreboard Boolean  @default(false)
  createdAt             DateTime @default(now())

  category TriviaCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@map("trivia_category_results")
}

model TriviaPowerUsage {
  id           String   @id @default(cuid())
  eventId      String?
  seedTag      String?
  userId       String
  powerType    String   // Airstrike, Solo Rider, Cockblock, Zadnji v Vrsti
  cost         Int
  categoryId   String?  // which category it was applied to
  targetUserId String?  // for Cockblock
  note         String?
  createdAt    DateTime @default(now())

  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([userId])
  @@map("trivia_power_usage")
}

model Person {
  id               String   @id @default(cuid())
  name             String
  profile_image_url String?
  createdAt        DateTime @default(now())
  users            User[]

  @@map("persons")
}

model PublicSighting {
  id                String    @id @default(cuid())
  eventId           String?
  seedTag           String?
  photoUrl          String
  latitude          Float
  longitude         Float
  submitterName     String?
  submitterCountry  String?
  message           String?
  actionType        String    @default("spot")
  points            Int       @default(1)
  friendshipLevel   String    @default("Witness")
  status            String    @default("pending")
  adminNotes        String?
  correctedLatitude  Float?
  correctedLongitude Float?
  approvedAt        DateTime?
  approvedByUserId  String?
  createdAt         DateTime  @default(now())

  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  admin User?  @relation(fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([status])
  @@index([actionType])

  @@map("public_sightings")
}

model HypeVote {
  id         String   @id @default(cuid())
  eventId    String?
  seedTag    String?
  suggestion String?
  voterName  String?
  createdAt  DateTime @default(now())

  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([eventId])

  @@map("hype_votes")
}

model AuthUser {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          String?
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  personId      String?
  sessions      AuthSession[]
  accounts      AuthAccount[]

  @@unique([email])
  @@map("user")
}

model AuthSession {
  id             String    @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model AuthAccount {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model HypeEvent {
  id             String    @id @default(cuid())
  eventId        String?
  seedTag        String?
  title          String
  description    String?
  status         String    @default("locked")
  voteThreshold  Int       @default(5)
  voteCount      Int       @default(0)
  unlockedAt     DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([eventId])

  @@map("hype_events")
}
